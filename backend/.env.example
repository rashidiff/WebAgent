# Copy this file to .env and fill in the values you need.

# Which LLM provider to use: gemini | openai | anthropic | deepseek
LLM_PROVIDER=deepseek

# Optional: override the default model for the chosen provider
LLM_MODEL_NAME=deepseek-chat

# Optional: cap on output tokens per LLM call (applies to all providers)
LLM_MAX_TOKENS=2048

# Provider API keys (only the one matching LLM_PROVIDER is required)
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# WebSocket server bind settings
HOST=127.0.0.1
PORT=8000

# Optional: comma-separated list of origins allowed to call the GET /sessions* HTTP
# endpoints from browser JS (CORS). Leave empty (default) to block all cross-origin
# access to session history, since it's local-only debugging data.
CORS_ALLOWED_ORIGINS=
